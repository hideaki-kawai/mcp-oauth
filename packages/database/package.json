{
  "name": "@mcp-oauth/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/mcp/index.ts",
    "./oauth": "./src/oauth/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "db:generate:mcp": "drizzle-kit generate --config=drizzle.config.mcp.ts",
    "db:generate:oauth": "drizzle-kit generate --config=drizzle.config.oauth.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.9.3"
  }
}
