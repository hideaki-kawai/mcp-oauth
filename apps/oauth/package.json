{
  "name": "@mcp-oauth/oauth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 30002",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply oauth-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply oauth-db --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mcp-oauth/constants": "workspace:*",
    "@mcp-oauth/database": "workspace:*",
    "@mcp-oauth/types": "workspace:*",
    "@mcp-oauth/utils": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.12.15"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@cloudflare/workers-types": "^4.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "tailwindcss": "^4.2.4",
    "vite": "^6.3.5",
    "wrangler": "^4.17.0"
  }
}
