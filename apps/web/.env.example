# api-mcp サーバーの URL（Hono RPC クライアントが叩く先）
# ローカル開発:
VITE_API_BASE_URL=http://localhost:30001
# 本番:
# VITE_API_BASE_URL=https://api-mcp.h-kawai-tech.workers.dev

# OAuth サーバーの URL（/login から /authorize へリダイレクトする先）
# ローカル開発:
VITE_OAUTH_BASE_URL=http://localhost:30002
# 本番:
# VITE_OAUTH_BASE_URL=https://oauth.h-kawai-tech.workers.dev

# Web アプリ自身の URL（OAuth コールバック URI に使用）
# ローカル開発:
VITE_WEB_BASE_URL=http://localhost:30000
# 本番:
# VITE_WEB_BASE_URL=https://web.h-kawai-tech.workers.dev
